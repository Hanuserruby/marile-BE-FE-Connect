// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id         String   @id @default(uuid())
  name       String
  username   String   @unique
  password   String
  role       Role
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  refreshToken RefreshToken[]
  transaction  Transaction[]
  inventoryLog InventoryLog[]

  @@map("users")
}

enum Role {
  admin
  cashier
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique @db.VarChar(512)
  expired_at DateTime
  created_at DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Product {
  id          String          @id @default(uuid())
  name        String
  description String?         @db.Text
  category    ProductCategory
  price       Decimal         @db.Decimal(12, 2)
  stock       Decimal         @default(0) @db.Decimal(10, 3)
  unit        Unit            @default(kg)
  image_url   String?
  is_active   Boolean         @default(true)
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt

  transactionItems TransactionItem[]
  inventoryLogs    InventoryLog[]

  @@map("products")
}

enum Unit {
  kg
  pcs
  ekor
}

enum ProductCategory {
  sayur
  protein
  buah
  lainnya
}

model Transaction {
  id             String            @id @default(uuid())
  cashierId      String
  invoice_no     String            @unique
  payment_method PaymentMethod     @default(Cash)
  total          Decimal           @db.Decimal(12, 2)
  amount_paid    Decimal           @db.Decimal(12, 2)
  change         Decimal           @db.Decimal(12, 2)
  status         TransactionStatus @default(completed)
  created_at     DateTime          @default(now())

  cashier          User              @relation(fields: [cashierId], references: [id])
  transactionItems TransactionItem[]

  @@map("transactions")
}

enum PaymentMethod {
  Cash
  Qris
  BankTransfer
}

enum TransactionStatus {
  completed
  canceled
}

model TransactionItem {
  id             String  @id @default(uuid())
  transactionsId String
  productsId     String
  product_name   String
  quantity       Decimal @db.Decimal(10, 3)
  unit_price     Decimal @db.Decimal(12, 2)
  sub_total      Decimal @db.Decimal(12, 2)

  product     Product     @relation(fields: [productsId], references: [id])
  transaction Transaction @relation(fields: [transactionsId], references: [id], onDelete: Cascade)

  @@map("transaction_items")
}

model InventoryLog {
  id         String   @id @default(uuid())
  productsId String
  created_by String?
  type       LogsType
  note       String?
  quantity   Decimal  @db.Decimal(10, 3)
  created_at DateTime @default(now())

  product Product @relation(fields: [productsId], references: [id])
  user    User?   @relation(fields: [created_by], references: [id])

  @@map("inventory_logs")
}

enum LogsType {
  restock
  sale
  adjustment
  void
}
